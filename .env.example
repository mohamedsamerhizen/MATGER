# Used by docker-compose.yml for the local SQL Server container.
SA_PASSWORD=Your_strong_password123!

# Optional ASP.NET Core development overrides.
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=MATGERDb;User Id=sa;Password=Your_strong_password123!;Encrypt=False;TrustServerCertificate=True;
Jwt__Issuer=MATGER
Jwt__Audience=MATGER.Client
Jwt__SecretKey=CHANGE_ME_TO_A_LONG_RANDOM_DEVELOPMENT_SECRET_1234567890
Jwt__AccessTokenExpirationMinutes=15
